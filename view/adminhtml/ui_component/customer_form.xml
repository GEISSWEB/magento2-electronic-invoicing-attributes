<form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Ui:etc/ui_configuration.xsd">
    <fieldset name="einvoicing" sortOrder="100">
        <settings>
            <collapsible>true</collapsible>
            <label translate="true">E-Invoicing</label>
        </settings>
        <field name="buyer_reference" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Buyer Reference</label>
                <notice translate="true">Buyer routing identifier for electronic invoicing (e.g., Leitweg-ID for German public sector, cost center, etc.) - EN16931 BT-10</notice>
                <dataScope>customer.buyer_reference</dataScope>
            </settings>
        </field>
        <field name="buyer_registration" formElement="input">
            <settings>
                <dataType>text</dataType>
                <label translate="true">Company Registration</label>
                <notice translate="true">Legal registration identifier (e.g., HRB number, SIREN, etc.) - EN16931 BT-47</notice>
                <dataScope>customer.buyer_registration</dataScope>
            </settings>
        </field>
    </fieldset>
</form>
